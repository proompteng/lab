{
  "name": "kabina",
  "version": "0.1.0",
  "private": true,
  "author": "",
  "type": "module",
  "main": "dist-electron/main.js",
  "scripts": {
    "dev": "run-p dev:renderer dev:main",
    "dev:renderer": "vite --clearScreen false",
    "dev:main": "run-s clean:main build:main dev:main:watch",
    "dev:main:watch": "concurrently -k \"tsc -w --project tsconfig.electron.json\" \"wait-on http://localhost:5173 && electron .\"",
    "clean:main": "rimraf dist-electron",
    "clean": "rimraf dist dist-electron",
    "build": "run-s build:renderer build:main",
    "build:renderer": "vite build",
    "build:main": "tsc --project tsconfig.electron.json",
    "start": "electron .",
    "lint:oxlint": "oxlint --config ../../.oxlintrc.json .",
    "lint:oxlint:type": "oxlint --config ../../.oxlintrc.json --type-aware --tsconfig ./tsconfig.json . && oxlint --config ../../.oxlintrc.json --type-aware --tsconfig ./tsconfig.electron.json electron"
  },
  "dependencies": {
    "@kubernetes/client-node": "^1.4.0",
    "react": "19.2.5",
    "react-dom": "19.2.5",
    "react-router-dom": "^7.15.0"
  },
  "devDependencies": {
    "@tailwindcss/vite": "4.2.4",
    "@types/node": "25.6.0",
    "@types/react": "19.2.15",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "6.0.1",
    "concurrently": "9.2.1",
    "electron": "41.5.0",
    "npm-run-all": "4.1.5",
    "rimraf": "6.1.3",
    "tailwindcss": "4.2.4",
    "typescript": "^7.0.2",
    "vite": "8.0.10",
    "wait-on": "9.0.5"
  }
}
