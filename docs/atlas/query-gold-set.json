{
  "version": "atlas-code-search-gold-v1",
  "repository": "proompteng/lab",
  "ref": "main",
  "queries": [
    {
      "query": "createAtlasCodeSearchHandlers",
      "expectedPaths": ["services/jangar/src/server/atlas-code-search.ts"],
      "expectedFirst": true
    },
    {
      "query": "ATLAS_CHUNKER_VERSION",
