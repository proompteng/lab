{
  "name": "@proompteng/cx-tools",
  "version": "0.0.0",
  "private": true,
  "bin": {
    "codex-nats-publish": "./dist/codex-nats-publish.js",
    "codex-nats-soak": "./dist/codex-nats-soak.js",
    "cx-codex-run": "./dist/cx-codex-run.js",
    "cx-workflow-cancel": "./dist/cx-workflow-cancel.js",
    "cx-workflow-query": "./dist/cx-workflow-query.js",
    "cx-workflow-signal": "./dist/cx-workflow-signal.js",
    "cx-workflow-start": "./dist/cx-workflow-start.js"
  },
  "type": "module",
  "scripts": {
    "build": "bun build src/cli/codex-nats-publish.ts src/cli/codex-nats-soak.ts src/cli/cx-codex-run.ts src/cli/cx-workflow-start.ts src/cli/cx-workflow-cancel.ts src/cli/cx-workflow-query.ts src/cli/cx-workflow-signal.ts --outdir dist --target node --sourcemap=none --minify",
    "lint": "bun run lint:oxlint || true",
    "lint:oxlint": "oxlint --config ../../.oxlintrc.json .",
    "lint:oxlint:type": "oxlint --config ../../.oxlintrc.json --type-aware --tsconfig ./tsconfig.json ."
  },
  "dependencies": {},
  "devDependencies": {
    "@types/bun": "^1.3.14",
    "typescript": "6.0.3"
  }
}
