{
  "name": "@proompteng/agent-contracts",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./agents-service-client": {
      "types": "./dist/agents-service-client.d.ts",
      "default": "./dist/agents-service-client.js"
    },
    "./agents-ready": {
      "types": "./dist/agents-ready.d.ts",
      "default": "./dist/agents-ready.js"
    },
    "./agent-message-artifacts": {
      "types": "./dist/agent-message-artifacts.d.ts",
      "default": "./dist/agent-message-artifacts.js"
    },
    "./agent-run-callbacks": {
      "types": "./dist/agent-run-callbacks.d.ts",
      "default": "./dist/agent-run-callbacks.js"
    },
    "./control-plane-status": {
      "types": "./dist/control-plane-status.d.ts",
      "default": "./dist/control-plane-status.js"
    },
    "./torghut-market-context-agentrun": {
      "types": "./dist/torghut-market-context-agentrun.d.ts",
      "default": "./dist/torghut-market-context-agentrun.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "test": "bunx vitest run ./src/agents-service-client.test.ts ./src/agents-ready.test.ts ./src/agent-message-artifacts.test.ts ./src/agent-run-callbacks.test.ts ./src/torghut-market-context-agentrun.test.ts",
    "tsc": "tsc --noEmit -p tsconfig.json",
    "lint": "bunx oxfmt --check src",
    "lint:oxlint": "oxlint --config ../../.oxlintrc.json .",
    "lint:oxlint:type": "oxlint --config ../../.oxlintrc.json --type-aware --tsconfig ./tsconfig.json ."
  },
  "devDependencies": {
    "bun-types": "1.3.13",
    "typescript": "6.0.3"
  },
  "packageManager": "bun@1.3.13"
}
