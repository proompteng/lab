  "scripts": {
    "build": "tsc -p tsconfig.json",
    "test": "bunx vitest run ./src/agents-clients.test.ts ./src/agents-ready.test.ts ./src/agent-message-artifacts.test.ts ./src/agent-run-projection-authority-client.test.ts ./src/agent-run-reruns-client.test.ts ./src/agent-run-terminal-events-client.test.ts ./src/codex-orchestration-parameters.test.ts ./src/codex-runs-client.test.ts ./src/control-plane-status.test.ts ./src/controller-witness.test.ts ./src/execution-trust.test.ts ./src/json.test.ts ./src/policy-validation.test.ts ./src/runtime-admission.test.ts ./src/signals-client.test.ts ./src/swarm-analysis.test.ts",
    "tsc": "tsc --noEmit -p tsconfig.json",
    "lint": "bunx oxfmt --check src",
    "lint:oxlint": "oxlint --config ../../.oxlintrc.json .",
    "lint:oxlint:type": "oxlint --config ../../.oxlintrc.json --type-aware --tsconfig ./tsconfig.json ."
