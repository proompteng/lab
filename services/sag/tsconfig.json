{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "types": ["vite/client", "node"],
    "module": "ESNext",
    "moduleResolution": "bundler",
    "jsx": "react-jsx",
    "allowImportingTsExtensions": true,
    "noEmit": true,
    "strict": true,
    "paths": {
      "~/*": ["./src/*"],
      "@/*": ["./src/*"],
      "@proompteng/codex": ["../../packages/codex/src/index.ts"]
    }
  },
  "include": ["src/**/*"]
}
