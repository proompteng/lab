{
  "name": "@proompteng/bayn",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "bun build src/index.ts src/backfill.ts --target=node --packages=external --outdir=dist",
    "dev": "bun --watch src/index.ts",
    "start": "node dist/index.js",
    "backfill": "bun src/backfill.ts",
    "lint": "bunx oxfmt --check src",
    "lint:oxlint": "oxlint --config ../../.oxlintrc.json .",
    "lint:oxlint:type": "oxlint --config ../../.oxlintrc.json --type-aware --tsconfig ./tsconfig.json .",
    "test": "bun test",
    "tsc": "bunx tsc --noEmit"
  },
  "dependencies": {
    "@clickhouse/client": "^1.23.1",
    "effect": "^3.21.2",
    "tigerbeetle-node": "0.17.4"
  },
  "devDependencies": {
    "@types/bun": "1.3.14",
    "@types/node": "^25.6.0",
    "typescript": "^7.0.2"
  },
  "packageManager": "bun@1.3.14"
}
