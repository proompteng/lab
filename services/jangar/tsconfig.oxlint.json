{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "jsx": "react-jsx",
    "noEmit": true,
    "strict": true,
    "strictNullChecks": true,
    "paths": {
      "@/*": ["./src/*"],
      "~/*": ["./src/*"],
      "@proompteng/agents": ["../agents/src/index.ts"],
      "@proompteng/agents/*": ["../agents/src/*"],
      "@proompteng/codex": ["../../packages/codex/src/index.ts"],
      "@proompteng/codex/*": ["../../packages/codex/src/*"],
      "@proompteng/otel": ["../../packages/otel/src/index.ts"],
      "@proompteng/otel/*": ["../../packages/otel/src/*.ts"]
    }
  },
  "include": ["./src/**/*"]
}
