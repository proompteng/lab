{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "jsx": "react-jsx",
    "noEmit": true,
    "strict": true,
    "strictNullChecks": true,
    "types": ["vite/client"],
    "paths": {
      "@/*": ["./src/*"],
      "~/*": ["./src/*"],
      "@proompteng/bumba/*": ["../bumba/*"],
      "@proompteng/codex": ["../../packages/codex/src/index.ts"],
      "@proompteng/codex/*": ["../../packages/codex/src/*"],
      "@proompteng/design": ["../../packages/design/src/index.ts"],
      "@proompteng/design/*": ["../../packages/design/src/*"],
      "@proompteng/temporal-bun-sdk": ["../../packages/temporal-bun-sdk/src/index.ts"],
      "@proompteng/temporal-bun-sdk/worker": ["../../packages/temporal-bun-sdk/src/worker/index.ts"],
      "@proompteng/temporal-bun-sdk/workflow": ["../../packages/temporal-bun-sdk/src/workflow/index.ts"],
      "@proompteng/temporal-bun-sdk/*": [
        "../../packages/temporal-bun-sdk/src/*/index.ts",
        "../../packages/temporal-bun-sdk/src/*.ts"
      ]
    }
  },
  "include": ["./src/**/*", "./vite.config.ts", "./vite.server.config.ts"]
}
