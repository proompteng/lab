+func createMockHTTPWatchServer() *httptest.Server {
+	server := httptest.NewTLSServer(http.HandlerFunc(func(w http.ResponseWriter, r *http.Request) {
+		if r.URL.Query().Get("watch") == "" {
+			http.Error(w, "missing watch query", http.StatusBadRequest)
+			return
+		}
+
+		w.Header().Set("Content-Type", "application/json")
+
+		flusher, ok := w.(http.Flusher)
+		if !ok {
+			http.Error(w, "streaming unsupported", http.StatusInternalServerError)
+			return
+		}
+
+		for _, event := range []string{
+			`{"type":"ADDED","object":{"metadata":{"resourceVersion":"1"}}}`,
+			`{"type":"MODIFIED","object":{"metadata":{"resourceVersion":"2"}}}`,
+		} {
+			_, _ = w.Write([]byte(event + "\n"))
+			flusher.Flush()
+		}
+
+		time.Sleep(500 * time.Millisecond)
+	}))
+
+	server.Client().Transport.(*http.Transport).TLSClientConfig = &tls.Config{
+		InsecureSkipVerify: true, //nolint:gosec
+	}
+
+	return server
+}
