+func TestGetOrCreateConnection_HTTPWatchStream(t *testing.T) {
+	store := kubeconfig.NewContextStore()
+	m := NewMultiplexer(store)
+
+	mockServer := createMockHTTPWatchServer()
+	defer mockServer.Close()
+
+	err := store.AddContext(&kubeconfig.Context{
+		Name: "test-cluster",
+		Cluster: &api.Cluster{
+			Server:                   mockServer.URL,
+			InsecureSkipTLSVerify:    true,
+			CertificateAuthorityData: nil,
+		},
+	})
+	require.NoError(t, err)
+
+	clientConn, clientServer := createTestWebSocketConnection()
+	defer clientServer.Close()
+
+	msg := Message{
+		ClusterID: "test-cluster",
+		Path:      "/api/v1/pods",
+		Query:     "watch=true",
+		UserID:    "test-user",
+	}
+
+	token := "test-token"
+	conn, err := m.getOrCreateConnection(msg, clientConn, &token)
+	require.NoError(t, err)
+	require.NotNil(t, conn)
+
+	receivedVersions := map[string]bool{}
+	deadline := time.Now().Add(2 * time.Second)
+
+	for len(receivedVersions) < 2 && time.Now().Before(deadline) {
+		var wrapper Message
+		err := clientConn.ReadJSON(&wrapper)
+		require.NoError(t, err)
+
+		if wrapper.Type != "DATA" {
+			continue
+		}
+
+		var event struct {
+			Object struct {
+				Metadata struct {
+					ResourceVersion string `json:"resourceVersion"`
+				} `json:"metadata"`
+			} `json:"object"`
+		}
+
+		err = json.Unmarshal([]byte(wrapper.Data), &event)
+		require.NoError(t, err)
+
+		receivedVersions[event.Object.Metadata.ResourceVersion] = true
+	}
+
+	assert.True(t, receivedVersions["1"])
+	assert.True(t, receivedVersions["2"])
+
+	m.CloseConnection(msg.ClusterID, msg.Path, msg.UserID)
+}
