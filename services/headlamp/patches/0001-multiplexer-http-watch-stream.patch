+
+func isWatchQuery(rawQuery string) bool {
+	values, err := url.ParseQuery(rawQuery)
+	if err != nil {
+		return false
+	}
+
+	switch strings.ToLower(values.Get("watch")) {
+	case "1", "true":
+		return true
+	default:
+		return false
+	}
+}
+
+func createHTTPRequestURL(host, path, query, resourceVersion string) string {
+	u, _ := url.Parse(host)
+	u.Path = path
+
+	values, err := url.ParseQuery(query)
+	if err != nil {
+		u.RawQuery = query
+		return u.String()
+	}
+
+	if resourceVersion != "" {
+		values.Set("resourceVersion", resourceVersion)
+	}
+
+	u.RawQuery = values.Encode()
+
+	return u.String()
+}
