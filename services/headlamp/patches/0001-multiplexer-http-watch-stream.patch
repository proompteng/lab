+func (m *Multiplexer) handleHTTPWatchStream(conn *Connection, config *rest.Config) {
+	defer m.cleanupConnection(conn)
+
+	ctx, cancel := context.WithCancel(context.Background())
+	conn.mu.Lock()
+	conn.watchCancel = cancel
+	conn.mu.Unlock()
+	defer cancel()
+
+	go func() {
+		select {
+		case <-conn.Done:
+			cancel()
+		case <-ctx.Done():
+		}
+	}()
+
+	var lastResourceVersion string
+
+	for {
+		err := m.streamHTTPWatch(ctx, conn, config, &lastResourceVersion)
+		if err == nil {
+			if ctx.Err() != nil || conn.closed {
+				return
+			}
+
+			conn.updateStatus(StateConnecting, nil)
+
+			select {
+			case <-time.After(time.Second):
+				continue
+			case <-ctx.Done():
+				return
+			}
+		}
+
+		if errors.Is(err, context.Canceled) || errors.Is(err, io.EOF) {
+			return
+		}
+
+		conn.updateStatus(StateError, err)
+		logger.Log(
+			logger.LevelError,
+			map[string]string{"clusterID": conn.ClusterID, "userID": conn.UserID},
+			err,
+			"reading cluster watch stream",
+		)
+
+		select {
+		case <-time.After(time.Second):
+			conn.updateStatus(StateConnecting, nil)
+		case <-ctx.Done():
+			return
+		}
+	}
+}
+
+func (m *Multiplexer) streamHTTPWatch(
+	ctx context.Context,
+	conn *Connection,
+	config *rest.Config,
+	lastResourceVersion *string,
+) error {
+	transport, err := rest.TransportFor(config)
+	if err != nil {
+		return fmt.Errorf("building watch transport: %w", err)
+	}
+
+	client := &http.Client{Transport: transport}
+
+	req, err := http.NewRequestWithContext(
+		ctx,
+		http.MethodGet,
+		createHTTPRequestURL(config.Host, conn.Path, conn.Query, *lastResourceVersion),
+		nil,
+	)
+	if err != nil {
+		return fmt.Errorf("creating watch request: %w", err)
+	}
+
+	req.Header.Set("Accept", "application/json")
+	if conn.Token != nil && *conn.Token != "" {
+		req.Header.Set("Authorization", "Bearer "+*conn.Token)
+	}
+
+	resp, err := client.Do(req)
+	if err != nil {
+		return fmt.Errorf("starting watch request: %w", err)
+	}
+	defer resp.Body.Close()
+
+	if resp.StatusCode != http.StatusOK {
+		body, _ := io.ReadAll(io.LimitReader(resp.Body, 4096))
+		bodyText := strings.TrimSpace(string(body))
+		if bodyText != "" {
+			return fmt.Errorf("watch request failed: %s: %s", resp.Status, bodyText)
+		}
+
+		return fmt.Errorf("watch request failed: %s", resp.Status)
+	}
+
+	conn.updateStatus(StateConnected, nil)
+
+	decoder := json.NewDecoder(resp.Body)
+	for {
+		var raw json.RawMessage
+		if err := decoder.Decode(&raw); err != nil {
+			if errors.Is(err, io.EOF) {
+				return nil
+			}
+
+			return fmt.Errorf("decoding watch event: %w", err)
+		}
+
+		if len(raw) == 0 {
+			continue
+		}
+
+		if err := m.sendIfNewResourceVersion(raw, conn, conn.Client, lastResourceVersion); err != nil {
+			return err
+		}
+
+		if err := m.sendDataMessage(conn, conn.Client, websocket.TextMessage, raw); err != nil {
+			return err
+		}
+	}
+}
