+// GetWebSocketCookiePath returns the websocket multiplexer cookie path including baseURL.
+func GetWebSocketCookiePath(baseURL string) string {
+	if baseURL != "" {
+		baseURL = "/" + strings.Trim(baseURL, "/")
+		return baseURL + "/wsMultiplexer"
+	}
+
+	return "/wsMultiplexer"
+}
+
+// GetBaseCookiePath returns the application base path including baseURL.
+func GetBaseCookiePath(baseURL string) string {
+	if baseURL != "" {
+		return "/" + strings.Trim(baseURL, "/")
+	}
+
+	return "/"
+}
+
+func getSetCookiePaths(baseURL, cluster string) []string {
+	return []string{GetCookiePath(baseURL, cluster), GetWebSocketCookiePath(baseURL)}
+}
+
+func getClearCookiePaths(baseURL, cluster string) []string {
+	paths := []string{GetCookiePath(baseURL, cluster), GetWebSocketCookiePath(baseURL), "/"}
+	basePath := GetBaseCookiePath(baseURL)
+	if basePath != "/" {
+		paths = append(paths, basePath)
+	}
+
+	return paths
+}
