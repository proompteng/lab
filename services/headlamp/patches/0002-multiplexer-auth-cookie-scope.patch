+func TestGetWebSocketCookiePath(t *testing.T) {
+	tests := []struct {
+		name    string
+		baseURL string
+		want    string
+	}{
+		{name: "empty base URL", baseURL: "", want: "/wsMultiplexer"},
+		{name: "base URL without leading slash", baseURL: "headlamp", want: "/headlamp/wsMultiplexer"},
+		{name: "base URL with leading slash", baseURL: "/headlamp", want: "/headlamp/wsMultiplexer"},
+		{name: "base URL with trailing slash", baseURL: "/headlamp/", want: "/headlamp/wsMultiplexer"},
+	}
+
+	for _, tt := range tests {
+		t.Run(tt.name, func(t *testing.T) {
+			got := auth.GetWebSocketCookiePath(tt.baseURL)
+			if got != tt.want {
+				t.Errorf("GetWebSocketCookiePath() = %q, want %q", got, tt.want)
+			}
+		})
+	}
+}
+
