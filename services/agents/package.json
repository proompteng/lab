{
  "name": "@proompteng/agents",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "exports": {
    "./server/controller-startup-retry": "./src/server/controller-startup-retry.ts",
    "./server/env-compat": "./src/server/env-compat.ts",
    "./server/kube-gateway": "./src/server/kube-gateway.ts",
    "./server/kube-types": "./src/server/kube-types.ts",
    "./server/kubernetes-bun-transport": "./src/server/kubernetes-bun-transport.ts",
    "./server/primitives": "./src/server/primitives.ts",
    "./server/runtime-identity": "./src/server/runtime-identity.ts",
    "./server/agents-controller/*": "./src/server/agents-controller/*.ts",
    "./runner/*": "./src/runner/*.ts"
  },
  "scripts": {
    "test": "bunx vitest run --config vitest.config.ts",
    "tsc": "bunx tsc --noEmit -p tsconfig.json",
    "lint": "bunx oxfmt --check src scripts",
    "lint:oxlint": "oxlint --config ../../.oxlintrc.json .",
    "lint:oxlint:type": "oxlint --config ../../.oxlintrc.json --type-aware --tsconfig ./tsconfig.json ."
  },
  "dependencies": {
    "@bufbuild/cel": "^0.4.0",
    "@kubernetes/client-node": "^1.4.0",
    "@proompteng/codex": "workspace:*",
    "@proompteng/temporal-bun-sdk": "workspace:*",
    "effect": "3.21.2",
    "xstate": "5.31.0"
  },
  "devDependencies": {
    "@types/node": "25.6.0",
    "bun-types": "1.3.13",
    "typescript": "^6.0.3",
    "vitest": "4.1.5"
  },
  "packageManager": "bun@1.3.13"
}
