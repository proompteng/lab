{
  "name": "@proompteng/bonjour",
  "version": "0.1.0",
  "private": true,
  "description": "Example Hono server with cdk8s manifests generated through the CLI for Argo CD CMP integration.",
  "main": "dist/server.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "dev": "tsx src/server.ts",
    "build": "tsc --project tsconfig.json --noEmit false --sourceMap true --declaration true --declarationDir dist",
    "synth": "bunx cdk8s-cli synth --no-check-upgrade",
    "clean": "rimraf dist manifests",
    "lint:oxlint": "oxlint --config ../../.oxlintrc.json .",
    "lint:oxlint:type": "oxlint --config ../../.oxlintrc.json --type-aware --tsconfig ./tsconfig.json . && oxlint --config ../../.oxlintrc.json --type-aware --tsconfig ./infra/tsconfig.json infra"
  },
  "dependencies": {
    "@hono/node-server": "^2.0.1",
    "@proompteng/otel": "workspace:*",
    "hono": "^4.12.16",
    "pino": "^10.3.1",
    "pino-loki": "^3.0.0",
    "tslib": "^2.8.1"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "cdk8s": "^2.70.60",
    "cdk8s-cli": "^2.206.10",
    "cdk8s-plus-33": "^2.5.10",
    "constructs": "^10.6.0",
    "rimraf": "^6.1.3",
    "tsx": "^4.21.0"
  }
}
